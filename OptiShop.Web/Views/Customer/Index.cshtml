@model IEnumerable<OptiShop.Models.Customer>
@{ ViewData["Title"] = "Quản lý khách hàng"; }

<div class="card-panel">
    <div class="card-panel-header">
        <form method="get" class="d-flex gap-2">
            <input type="text" name="keyword" class="form-control" placeholder="Tìm tên hoặc SĐT..." value="@ViewBag.Keyword" style="width:280px;" />
            <button class="btn btn-ghost"><i class="bi bi-search"></i> Tìm</button>
        </form>
        <a href="/Customer/Create" class="btn btn-primary"><i class="bi bi-plus"></i> Thêm khách hàng</a>
    </div>
    <div class="card-panel-body compact" style="padding:0;">
        <table class="table table-hover">
            <thead><tr><th>Họ tên</th><th>Số điện thoại</th><th>Email</th><th>Địa chỉ</th><th class="text-center" style="width:120px;">Thao tác</th></tr></thead>
            <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td><span class="fw-semibold" style="color:var(--gray-900);">@c.FullName</span></td>
                    <td>@c.Phone</td><td>@c.Email</td><td>@c.Address</td>
                    <td class="text-center">
                        <div class="d-flex gap-1 justify-content-center">
                            <a href="/Customer/Details/@c.CustomerId" class="btn btn-sm btn-ghost"><i class="bi bi-eye"></i></a>
                            <a href="/Customer/Edit/@c.CustomerId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state"><i class="bi bi-people"></i><p>Chưa có khách hàng nào</p></div>
        }
    </div>
</div>
