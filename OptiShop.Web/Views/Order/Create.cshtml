@{ ViewData["Title"] = "Tạo đơn hàng"; }

<div class="row g-4">
    <div class="col-md-8">
        <div class="table-container">
            <h5 class="fw-bold mb-3"><i class="bi bi-box-seam"></i> Chọn sản phẩm</h5>
            <input type="text" id="searchProduct" class="form-control mb-3" placeholder="Tìm tên sản phẩm..." />
            <table class="table table-hover align-middle" id="productTable">
                <thead class="table-light"><tr><th>Hình</th><th>Sản phẩm</th><th class="text-end">Giá</th><th class="text-center">Kho</th><th class="text-center">Thêm</th></tr></thead>
                <tbody>
                @foreach (var p in (IEnumerable<OptiShop.Models.Product>)ViewBag.Products)
                {
                    @if (p.IsActive && p.Stock > 0)
                    {
                        <tr>
                            <td><img src="@(p.ImageUrl ?? "/images/no-image.png")" style="width:40px;height:40px;object-fit:cover;border-radius:6px;" /></td>
                            <td class="fw-semibold">@p.ProductName</td>
                            <td class="text-end">@p.Price.ToString("N0") đ</td>
                            <td class="text-center"><span class="badge bg-success">@p.Stock</span></td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-outline-success" onclick="addItem(@p.ProductId, '@p.ProductName.Replace("'","\\'")', @p.Price, @p.Stock)">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-md-4">
        <div class="table-container">
            <h5 class="fw-bold mb-3"><i class="bi bi-cart3"></i> Đơn hàng</h5>
            <form method="post" id="orderForm">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Khách hàng *</label>
                    <select name="CustomerId" class="form-select" required asp-items="@((SelectList)ViewBag.Customers)"><option value="">-- Chọn KH --</option></select>
                </div>
                <input type="hidden" name="OrderType" value="TaiQuay" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">Ghi chú</label>
                    <textarea name="Note" class="form-control" rows="2"></textarea>
                </div>
                <hr />
                <div id="orderItems"></div>
                <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
                    <strong>Tổng cộng:</strong>
                    <span class="text-primary fw-bold fs-5" id="totalAmount">0 đ</span>
                </div>
                <button type="submit" class="btn btn-primary w-100" id="btnSubmit" disabled>
                    <i class="bi bi-check-circle"></i> Tạo đơn hàng
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
let items = [];
let idx = 0;

function addItem(productId, name, price, maxQty) {
    if (items.find(i => i.productId === productId)) { alert('SP đã có trong đơn!'); return; }
    items.push({ productId, name, price, maxQty, qty: 1 });
    renderItems();
}

function removeItem(productId) {
    items = items.filter(i => i.productId !== productId);
    renderItems();
}

function updateQty(productId, qty) {
    const item = items.find(i => i.productId === productId);
    if (item) { item.qty = Math.max(1, Math.min(qty, item.maxQty)); }
    renderItems();
}

function renderItems() {
    let html = '';
    let total = 0;
    items.forEach((item, i) => {
        total += item.price * item.qty;
        html += `<div class="d-flex justify-content-between align-items-center mb-2 p-2 bg-light rounded">
            <div>
                <div class="fw-semibold" style="font-size:0.9rem;">${item.name}</div>
                <small class="text-muted">${item.price.toLocaleString()} đ x </small>
                <input type="number" min="1" max="${item.maxQty}" value="${item.qty}" style="width:60px;" class="form-control form-control-sm d-inline" onchange="updateQty(${item.productId}, this.value)" />
            </div>
            <div class="text-end">
                <div class="fw-bold text-primary">${(item.price * item.qty).toLocaleString()} đ</div>
                <button type="button" class="btn btn-sm btn-outline-danger mt-1" onclick="removeItem(${item.productId})"><i class="bi bi-trash"></i></button>
            </div>
            <input type="hidden" name="Items[${i}].ProductId" value="${item.productId}" />
            <input type="hidden" name="Items[${i}].Quantity" value="${item.qty}" />
        </div>`;
    });
    document.getElementById('orderItems').innerHTML = html || '<p class="text-muted text-center">Chưa có sản phẩm</p>';
    document.getElementById('totalAmount').textContent = total.toLocaleString() + ' đ';
    document.getElementById('btnSubmit').disabled = items.length === 0;
}

document.getElementById('searchProduct').addEventListener('input', function() {
    const keyword = this.value.toLowerCase();
    document.querySelectorAll('#productTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(keyword) ? '' : 'none';
    });
});
</script>
}
