<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OptiShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="sidebar-brand-icon"><i class="bi bi-eyeglasses"></i></div>
                <span class="sidebar-brand-text">OptiShop</span>
            </div>
            <nav class="sidebar-nav">
                <div class="sidebar-section">Tổng quan</div>
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")" href="/">
                    <i class="bi bi-grid-1x2-fill"></i> Dashboard
                </a>

                <div class="sidebar-section">Quản lý</div>
                @if (User.IsInRole("Admin") || User.IsInRole("NVBanHang"))
                {
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")" href="/Product">
                        <i class="bi bi-box-seam-fill"></i> Sản phẩm
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")" href="/Customer">
                        <i class="bi bi-people-fill"></i> Khách hàng
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")" href="/Order">
                        <i class="bi bi-receipt"></i> Đơn hàng
                    </a>
                }
                @if (User.IsInRole("Admin") || User.IsInRole("NVKho"))
                {
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Warehouse" ? "active" : "")" href="/Warehouse">
                        <i class="bi bi-archive-fill"></i> Kho hàng
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Supplier" ? "active" : "")" href="/Supplier">
                        <i class="bi bi-truck"></i> Nhà cung cấp
                    </a>
                }

                <div class="sidebar-divider"></div>

                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Shop" ? "active" : "")" href="/Shop">
                    <i class="bi bi-shop"></i> Cửa hàng online
                </a>
            </nav>
            <div class="sidebar-footer">
                <a class="sidebar-link" href="/Account/Logout" style="color: rgba(239,68,68,0.7);">
                    <i class="bi bi-box-arrow-left"></i> Đăng xuất
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="topbar">
                <h1 class="topbar-title">@ViewData["Title"]</h1>
                <div class="topbar-user">
                    <div class="topbar-avatar">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                    <div>
                        <div style="font-weight:600; color:var(--gray-800); font-size:13px;">@User.Identity.Name</div>
                        <div style="font-size:12px; color:var(--gray-400);">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                    </div>
                </div>
            </header>
            <div class="page-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4">
                        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-4">
                        <i class="bi bi-exclamation-circle-fill"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    }
    else
    {
        @RenderBody()
    }
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
