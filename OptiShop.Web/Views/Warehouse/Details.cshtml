@model OptiShop.Models.ImportReceipt
@{ ViewData["Title"] = "Phiếu nhập #" + Model.ImportId; }

<div class="row g-4">
    <div class="col-md-4">
        <div class="card-panel">
            <div class="card-panel-header"><h5><i class="bi bi-archive-fill"></i> Thông tin phiếu nhập</h5></div>
            <div class="card-panel-body">
                <table class="table table-borderless info-table mb-0">
                    <tr><td>Mã phiếu</td><td class="fw-bold" style="color:var(--gray-900);">#@Model.ImportId</td></tr>
                    <tr><td>Nhà cung cấp</td><td class="fw-semibold">@Model.Supplier?.SupplierName</td></tr>
                    <tr><td>Ngày nhập</td><td>@Model.ImportDate.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    @if (!string.IsNullOrEmpty(Model.Note)) { <tr><td>Ghi chú</td><td>@Model.Note</td></tr> }
                    <tr><td>Tổng tiền</td><td class="price-lg">@Model.TotalAmount.ToString("N0") đ</td></tr>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card-panel">
            <div class="card-panel-header"><h5><i class="bi bi-list-check"></i> Chi tiết sản phẩm nhập</h5></div>
            <div class="card-panel-body compact" style="padding:0;">
                <table class="table">
                    <thead><tr><th>Sản phẩm</th><th class="text-center">Số lượng</th><th class="text-end">Đơn giá nhập</th><th class="text-end">Thành tiền</th></tr></thead>
                    <tbody>
                    @foreach (var d in Model.ImportDetails)
                    {
                        <tr>
                            <td class="fw-semibold" style="color:var(--gray-900);">@d.Product?.ProductName</td>
                            <td class="text-center">@d.Quantity</td>
                            <td class="text-end">@d.UnitPrice.ToString("N0") đ</td>
                            <td class="text-end price">@((d.UnitPrice * d.Quantity).ToString("N0")) đ</td>
                        </tr>
                    }
                    </tbody>
                    <tfoot><tr><td colspan="3" class="text-end fw-bold">Tổng cộng</td><td class="text-end price-lg">@Model.TotalAmount.ToString("N0") đ</td></tr></tfoot>
                </table>
            </div>
        </div>
    </div>
</div>
