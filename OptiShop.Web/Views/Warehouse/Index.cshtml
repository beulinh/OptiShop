@model IEnumerable<OptiShop.Models.ImportReceipt>
@{ ViewData["Title"] = "Quản lý kho hàng"; }
<div class="card-panel">
    <div class="card-panel-header">
        <h5><i class="bi bi-archive-fill"></i> Phiếu nhập kho</h5>
        <a href="/Warehouse/Create" class="btn btn-primary"><i class="bi bi-plus"></i> Tạo phiếu nhập</a>
    </div>
    <div class="card-panel-body compact" style="padding:0;">
        <table class="table table-hover">
            <thead><tr><th>Mã phiếu</th><th>Nhà cung cấp</th><th>Nhân viên</th><th>Ngày nhập</th><th class="text-end">Tổng tiền</th><th class="text-center" style="width:80px;"></th></tr></thead>
            <tbody>
            @foreach (var i in Model)
            {
                <tr>
                    <td><span class="fw-semibold" style="color:var(--gray-900);">#@i.ImportId</span></td>
                    <td>@i.Supplier?.SupplierName</td><td>@i.User?.FullName</td>
                    <td style="color:var(--gray-500);">@i.ImportDate.ToString("dd/MM/yyyy")</td>
                    <td class="text-end price">@i.TotalAmount.ToString("N0") đ</td>
                    <td class="text-center"><a href="/Warehouse/Details/@i.ImportId" class="btn btn-sm btn-ghost"><i class="bi bi-eye"></i></a></td>
                </tr>
            }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="empty-state"><i class="bi bi-archive"></i><p>Chưa có phiếu nhập nào</p></div>
        }
    </div>
</div>
