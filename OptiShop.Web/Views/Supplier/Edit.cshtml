@model OptiShop.Models.Supplier
@{ ViewData["Title"] = Model.SupplierId == 0 ? "Thêm nhà cung cấp" : "Sửa nhà cung cấp"; }
<div class="card-panel" style="max-width:580px;">
    <div class="card-panel-header"><h5><i class="bi bi-truck"></i> @ViewData["Title"]</h5></div>
    <div class="card-panel-body">
        <form method="post">
            <input type="hidden" name="SupplierId" value="@Model.SupplierId" />
            <input type="hidden" name="IsActive" value="@Model.IsActive" />
            <div class="mb-3"><label class="form-label">Tên NCC <span class="text-danger">*</span></label><input type="text" name="SupplierName" class="form-control" value="@Model.SupplierName" required /></div>
            <div class="mb-3"><label class="form-label">SĐT <span class="text-danger">*</span></label><input type="text" name="Phone" class="form-control" value="@Model.Phone" required /></div>
            <div class="mb-3"><label class="form-label">Email</label><input type="email" name="Email" class="form-control" value="@Model.Email" /></div>
            <div class="mb-4"><label class="form-label">Địa chỉ</label><input type="text" name="Address" class="form-control" value="@Model.Address" /></div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Lưu</button>
                <a href="/Supplier" class="btn btn-ghost">Hủy</a>
            </div>
        </form>
    </div>
</div>
